// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum OrderStatus {
  PENDING
  PAID
  SHIPPED
  COMPLETED
  CANCELLED
}

enum Role {
  ADMIN
  SELLER
  CUSTOMER
}

model User {
  id            Int      @id @default(autoincrement())
  email         String   @unique
  password      String
  role          Role     @default(CUSTOMER)
  token_version Int      @default(0)
  is_active     Boolean  @default(true)
  last_login    DateTime @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  orders      Order[]
  stores      Store[]
  cartItem    CartItem[]
  userProfile UserProfile?

  storeMembers StoreMember[]
  reviews      Review[]
}

model UserProfile {
  id          Int       @id @default(autoincrement())
  userId      Int       @unique
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName   String?
  lastName    String?
  avatarURL   String?
  bio         String?
  phone       String?
  dateOfBirth DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  isDeleted Boolean @default(false) //soft deletes
}

model Category {
  id        Int     @id @default(autoincrement())
  name      String  @unique
  slug      String  @unique
  is_active Boolean @default(true)

  parentId Int?
  parent   Category?  @relation("CategoryToCategory", fields: [parentId], references: [id])
  children Category[] @relation("CategoryToCategory")

  products Product[] // One-to-many relationship

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  isDeleted Boolean @default(false) //soft deletes
}

model Product {
  id          Int     @id @default(autoincrement())
  name        String
  description String?
  price       Decimal @db.Decimal(10, 2)
  categoryId  Int?
  slug        String
  storeId     Int
  is_active   Boolean @default(true)
  status      ProductStatus  @default(DRAFT) // ACTIVE, DRAFT, ARCHIVED

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  store    Store     @relation(fields: [storeId], references: [id])
  category Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)

  CartItem   CartItem[]
  images     ProductImage[]
  orderItems OrderItem[]
  inventory  Inventory?

  isDeleted Boolean  @default(false) //soft deletes
  reviews   Review[]

  @@unique([storeId, slug])
  //index for performance bootstrap
  @@index([storeId])
  @@index([categoryId])
}

model ProductImage {
  id  Int    @id @default(autoincrement())
  url String

  productId Int
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  type      String? // e.g. "thumbnail", "gallery"
  isDeleted Boolean @default(false) // soft deletes for images

  altText   String? // accessibility / SEO
  isPrimary Boolean @default(false) // main thumbnail
  sortOrder Int     @default(0) // ordering in UI

  createdAt DateTime @default(now())
}

model Inventory {
  id                Int      @id @default(autoincrement())
  productId         Int      @unique
  product           Product  @relation(fields: [productId], references: [id])
  quantity          Int
  lowStockThreshold Int      @default(5)
  updatedAt         DateTime @updatedAt

  isDeleted Boolean @default(false) //soft deletes
}

model StoreMember {
  id      Int  @id @default(autoincrement())
  userId  Int
  storeId Int
  role    Role // or separate enum

  user  User  @relation(fields: [userId], references: [id])
  store Store @relation(fields: [storeId], references: [id])

  isDeleted Boolean @default(false) // soft deletes

  @@unique([userId, storeId])
}

model Store {
  id        Int      @id @default(autoincrement())
  logoUrl   String?
  name      String   @unique
  slug      String   @unique
  userId    Int
  is_active Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  products Product[]
  user     User      @relation(fields: [userId], references: [id])

  isDeleted    Boolean       @default(false) //soft deletes
  storeMembers StoreMember[]
  orders       Order[]
}

model Order {
  id        Int         @id @default(autoincrement())
  userId    Int
  storeId   Int
  items     OrderItem[]
  status    OrderStatus @default(PENDING) // or enum later
  total     Decimal     @db.Decimal(10, 2)
  paidAt    DateTime?
  shippedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id])

  isDeleted Boolean @default(false) //soft deletes
}

model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Decimal @db.Decimal(10, 2)

  isDeleted Boolean @default(false) //soft deletes
}

model CartItem {
  id        Int      @id @default(autoincrement())
  userId    Int
  productId Int
  quantity  Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, productId]) // each user can only have one of the same product in cart
}

model InventorySnapshot {
  id         Int      @id @default(autoincrement())
  month      DateTime @unique
  totalValue Decimal  @db.Decimal(12, 2)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  isDeleted Boolean @default(false) //soft deletes
}

//for expansion adding reviews
model Review {
  id        Int     @id @default(autoincrement())
  userId    Int
  productId Int
  rating    Int
  comment   String?

  user    User    @relation(fields: [userId], references: [id])
  product Product @relation(fields: [productId], references: [id])

  isDeleted Boolean @default(false) //soft deletes

  @@unique([userId, productId]) //one call for uniquer for both userId and productId
}
